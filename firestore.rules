rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Content is managed mainly by admins, but writes are open to any signed-in user
    // so participant/admin flows never hit permission-denied. Security is low-stakes
    // here; we favour not having to touch rules for every feature. Reads are public.

    // Content is managed mainly by admins, but writes are open to any signed-in user
    // so participant/admin flows never hit permission-denied. Security is low-stakes
    // here; we favour not having to touch rules for every feature. Reads are public.
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /bars/{barId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Any signed-in user can read/write groups. Participant actions (joining,
    // advancing the crawl, score updates) touch groups other than their own, so a
    // member-only rule would deny them.

    // Any signed-in user can read/write groups. Participant actions (joining,
    // advancing the crawl, score updates) touch groups other than their own, so a
    // member-only rule would deny them.
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // Submissions: you can only create your own; approvals/deletions stay admin-only
    // so scoring can't be trivially forged.
    match /submissions/{submissionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
      );
      allow delete: if isAdmin();
    }

    // Crawl archives (end-of-night recap): readable by any signed-in user, written
    // only by the admin end-crawl flow.
    match /crawlArchives/{archiveId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users can only write their own profile document.

    // Crawl archives (end-of-night recap): readable by any signed-in user, written
    // only by the admin end-crawl flow.
    match /crawlArchives/{archiveId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users can only write their own profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
